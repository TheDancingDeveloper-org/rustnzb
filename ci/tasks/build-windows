#!/bin/sh
set -eu
. "$(dirname "$0")/lib.sh"
. "$(dirname "$0")/cargo-auth"
trap 'cleanup_cargo_auth; cleanup_frontend' EXIT
task_start build-windows cargo clang lld
setup_cargo_auth
task_target_dir build-windows
build_frontend
if [ -n "${CI_COMMIT_TAG:-}" ]; then
    export CARGO_PROFILE_RELEASE_LTO=fat CARGO_PROFILE_RELEASE_CODEGEN_UNITS=1 CARGO_PROFILE_RELEASE_STRIP=symbols
fi
cargo xwin build --release --target x86_64-pc-windows-msvc --features webdav --locked --accept-license
binary=$CARGO_TARGET_DIR/x86_64-pc-windows-msvc/release/rustnzb.exe
test -f "$binary"
file "$binary"
ls -lh "$binary"
show_sccache_stats
